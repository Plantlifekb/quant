def format_cum_return(value):
    try:
        if value is None:
            return ""
        multiplier = 1.0 + float(value)
        percent = float(value) * 100.0
        sign = "+" if percent >= 0 else ""
        return f"{multiplier:.3f}x ({sign}{percent:.2f}%)"
    except Exception:
        return str(value)

