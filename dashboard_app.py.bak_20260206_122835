def compute_period_returns(series: pd.Series):
    if len(series) < 1:
        return np.nan, np.nan, np.nan
    weekly = series.iloc[-1] if len(series) >= 1 else np.nan
    monthly = (1 + series.iloc[-4:]).prod() - 1 if len(series) >= 4 else np.nan
    annual = (1 + series.iloc[-52:]).prod() - 1 if len(series) >= 52 else np.nan
    return weekly, monthly, annual


