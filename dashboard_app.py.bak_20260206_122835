def compute_current_week_regime(prices_df: pd.DataFrame, date_col: str = "date") -> Dict:
    dfp = prices_df.copy()
    dfp[date_col] = pd.to_datetime(dfp[date_col])

    price_candidates = ["price", "close", "last", "adj_close", "adjusted_close"]
    pcol = next((c for c in price_candidates if c in dfp.columns), None)
    if pcol is None and {"open", "high", "low", "close"}.issubset(dfp.columns):
        dfp["__price_fallback__"] = dfp[["open", "high", "low", "close"]].mean(axis=1)
        pcol = "__price_fallback__"
    if pcol is None:
        return {"regime": "insufficient data", "reason": "no price column", "as_of": pd.Timestamp.utcnow().isoformat()}

    if "ticker" in dfp.columns:
        candidates = ["SPX", "SP500", "^GSPC", "SPY", "INDEX"]
        idx = next((c for c in candidates if c in dfp["ticker"].unique()), None)
        if idx:
            series = dfp.loc[dfp["ticker"] == idx, [date_col, pcol]].sort_values(date_col).set_index(date_col)[pcol].astype(float)
        else:
            pivot = dfp.pivot_table(index=date_col, columns="ticker", values=pcol)
            series = pivot.mean(axis=1).sort_index().astype(float)
    else:
        series = dfp.sort_values(date_col).set_index(date_col)[pcol].astype(float)

    series = series.dropna().sort_index()
    if len(series) < 60:
        return {"regime": "insufficient data", "reason": "not enough history", "as_of": pd.Timestamp.utcnow().isoformat()}

    latest = float(series.iloc[-1])
    ma50 = float(series.rolling(window=50, min_periods=20).mean().iloc[-1])
    ma200 = float(series.rolling(window=200, min_periods=50).mean().iloc[-1])
    daily_ret = series.pct_change().dropna()
    rv20 = float(daily_ret.rolling(window=20).std().iloc[-1] * np.sqrt(252))

    low_vol_threshold = 0.12
    high_vol_threshold = 0.25

    if latest > ma50 and ma50 > ma200 and rv20 < low_vol_threshold:
        regime = "Bull"
    elif latest > ma50 and rv20 >= low_vol_threshold:
        regime = "Risk-On"
    elif latest < ma200 and rv20 > high_vol_threshold:
        regime = "Bear"
    else:
        regime = "Transitional"

    return {"regime": regime, "latest": latest, "ma50": ma50, "ma200": ma200, "rv20": rv20, "as_of": pd.Timestamp.utcnow().isoformat()}


