def compute_regime(weekly_portfolio_df: pd.DataFrame):
    if len(weekly_portfolio_df) < 1:
        return np.nan, np.nan, np.nan
    last_week = weekly_portfolio_df["weekly_return"].iloc[-1] if len(weekly_portfolio_df) >= 1 else np.nan
    last_4 = weekly_portfolio_df["weekly_return"].iloc[-4:]
    monthly = (1 + last_4).prod() - 1 if len(last_4) == 4 else np.nan
    last_52 = weekly_portfolio_df["weekly_return"].iloc[-52:]
    annual = (1 + last_52).prod() - 1 if len(last_52) == 52 else np.nan
    return last_week, monthly, annual


