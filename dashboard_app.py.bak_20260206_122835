def institutional_plot(figsize=(5.6, 2.9)):
    fig, ax = plt.subplots(figsize=figsize)
    ax.grid(True, alpha=0.18, linewidth=0.6)
    ax.tick_params(labelsize=8)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.spines["left"].set_linewidth(0.6)
    ax.spines["bottom"].set_linewidth(0.6)
    return fig, ax


def plot_price_series_plotly(series_df: pd.DataFrame, date_col: str = "date", price_col: str = "close", title: str = "Index"):
    fig = go.Figure()
    fig.add_trace(go.Scatter(x=series_df[date_col], y=series_df[price_col], mode="lines", name="Close", line=dict(color="#00aaff", width=2)))
    if "ma50" in series_df.columns:
        fig.add_trace(go.Scatter(x=series_df[date_col], y=series_df["ma50"], mode="lines", name="MA50", line=dict(color="#ffaa00", width=1, dash="dash")))
    if "ma200" in series_df.columns:
        fig.add_trace(go.Scatter(x=series_df[date_col], y=series_df["ma200"], mode="lines", name="MA200", line=dict(color="#ff5555", width=1, dash="dot")))
    fig.update_layout(margin=dict(l=30, r=20, t=40, b=30), height=420, template="plotly_white", legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1))
    return fig


def plot_volatility_plotly(series_df: pd.DataFrame, date_col: str = "date", price_col: str = "close", window: int = 20):
    s = series_df.set_index(date_col)[price_col].sort_index().pct_change().dropna()
    rv = s.rolling(window=window).std() * np.sqrt(252)
    rv = rv.reset_index().rename(columns={price_col: "rv"})
    fig = go.Figure()
    fig.add_trace(go.Scatter(x=rv[date_col], y=rv["rv"], mode="lines", name=f"{window}-day RV", line=dict(color="#6a5acd")))
    fig.update_layout(margin=dict(l=30, r=20, t=40, b=30), height=420, template="plotly_white", legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1))
    return fig

