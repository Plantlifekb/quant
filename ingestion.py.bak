# quant/engine/tasks/ingestion.py
import os
import logging
import importlib
import importlib.util
from typing import Dict, Any, Optional

import pandas as pd

logger = logging.getLogger("quant.engine.tasks.ingestion")
logger.addHandler(logging.NullHandler())

# --- Robust fetcher import (backwards-compatible) --------------------------------
def _import_fetcher_module() -> Optional[Any]:
    """
    Try to import the project's ingestion fetcher module in a few ways:
    1. Direct import: quant.ingestion_5years_quant_v1 (or similar)
    2. Legacy path: quant.engine.tasks.ingestion_fetcher
    3. If a file path is provided via env var INGESTION_FETCHER_PATH, load it dynamically.
    Returns the module or None.
    """
    candidates = [
        "quant.ingestion_5years_quant_v1",
        "quant.ingestion",
        "quant.engine.tasks.ingestion_fetcher",
        "ingestion_5years_quant_v1",
    ]

    for name in candidates:
        try:
            mod = importlib.import_module(name)
            logger.info("Loaded fetcher module: %s", name)
            return mod
        except Exception:
            continue

    # Try loading from a path if provided
    path = os.getenv("INGESTION_FETCHER_PATH")
    if path and os.path.exists(path):
        try:
            spec = importlib.util.spec_from_file_location("quant_ingestion_fetcher", path)
            mod = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)  # type: ignore
            logger.info("Loaded fetcher module from path: %s", path)
            return mod
        except Exception as exc:
            logger.exception("Failed to load fetcher from path %s: %s", path, exc)

    logger.error("No ingestion fetcher module found. Tried: %s", candidates)
    return None


# --- DB write helper --------------------------------------------------------------
def write_prices_to_db(df: pd.DataFrame) -> int:
    """
    Write prices DataFrame to public.prices.
    Accepts either:
      - SQLAlchemy URL in env var DATABASE_URL (e.g. postgresql+psycopg2://user:pass@host:port/db)
      - libpq-style DSN string in env var PG_DSN
      - individual PG env vars (PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD)
    Returns number of rows written.
    """
    # Prefer explicit env var names in this order
    pg_dsn = os.getenv("DATABASE_URL") or os.getenv("PG_DSN") or os.getenv("PGCONN")
    # If no DSN provided, build libpq-style string from PG env vars
    if not pg_dsn:
        host = os.getenv("PGHOST", "localhost")
        port = os.getenv("PGPORT", "5432")
        dbname = os.getenv("PGDATABASE", os.getenv("PG_DB", "quant"))
        user = os.getenv("PGUSER", "quant")
        password = os.getenv("PGPASSWORD", os.getenv("PG_PASS", "quant"))
        # Use libpq-style string by default
        pg_dsn = f"host={host} port={port} dbname={dbname} user={user} password={password}"

    # If SQLAlchemy-style URL, use SQLAlchemy + pandas.to_sql
    if isinstance(pg_dsn, str) and (pg_dsn.startswith("postgresql+psycopg2://") or pg_dsn.startswith("postgresql://")):
        try:
            from sqlalchemy import create_engine
        except Exception as exc:
            logger.exception("sqlalchemy is required to use SQLAlchemy URLs: %s", exc)
            raise

        engine = create_engine(pg_dsn, pool_pre_ping=True)
        # Ensure DataFrame column names match DB schema; use if_exists='append'
        df.to_sql("prices", engine, schema="public", if_exists="append", index=False, method="multi")
        rows = len(df)
        logger.info("Wrote %d rows to public.prices via SQLAlchemy engine", rows)
        return rows

    # Otherwise assume libpq-style DSN or a plain postgres:// URL; use psycopg2
    try:
        import psycopg2
        from psycopg2 import sql
    except Exception as exc:
        logger.exception("psycopg2 is required for libpq-style DSNs: %s", exc)
        raise

    # If pg_dsn looks like a URL (postgres:// or postgresql://) parse it
    if pg_dsn.startswith("postgres://") or pg_dsn.startswith("postgresql://"):
        from urllib.parse import urlparse, unquote
        url = urlparse(pg_dsn)
        conn_kwargs = {
            "host": url.hostname,
            "port": url.port or 5432,
            "dbname": url.path.lstrip("/"),
            "user": url.username,
            "password": unquote(url.password) if url.password else None,
        }
        conn = psycopg2.connect(**{k: v for k, v in conn_kwargs.items() if v is not None})
    else:
        # libpq-style string
        conn = psycopg2.connect(pg_dsn)

    try:
        with conn:
            with conn.cursor() as cur:
                # Ensure table exists (minimal schema). Adjust types to match your real schema.
                cur.execute(
                    """
                    CREATE TABLE IF NOT EXISTS public.prices (
                        ticker text,
                        date date,
                        adj_close numeric,
                        close numeric,
                        high numeric,
                        low numeric,
                        open numeric,
                        volume bigint
                    );
                    """
                )
                # Prepare insert
                # Map DataFrame columns to DB columns (lowercase, canonical names)
                df_cols = [c for c in df.columns]
                # Normalize column names to match table
                col_map = {
                    "Date": "date",
                    "date": "date",
                    "Adj_Close": "adj_close",
                    "AdjClose": "adj_close",
                    "Adj Close": "adj_close",
                    "Close": "close",
                    "High": "high",
                    "Low": "low",
                    "Open": "open",
                    "Volume": "volume",
                    "ticker": "ticker",
                    "TICKER": "ticker",
                }
                db_cols = []
                for c in df_cols:
                    db_cols.append(col_map.get(c, c).lower())

                # Build SQL statement
                columns_sql = sql.SQL(", ").join(sql.Identifier(c) for c in db_cols)
                placeholders = sql.SQL(", ").join(sql.Placeholder() for _ in db_cols)
                insert_sql = sql.SQL("INSERT INTO public.prices ({cols}) VALUES ({vals})").format(
                    cols=columns_sql, vals=placeholders
                )

                # Convert DataFrame rows to list of tuples
                values = []
                for row in df.itertuples(index=False, name=None):
                    # Ensure types are basic Python types
                    values.append(tuple(None if pd.isna(x) else x for x in row))

                # Use executemany for batch insert
                cur.executemany(insert_sql.as_string(cur), values)
        rows = len(df)
        logger.info("Wrote %d rows to public.prices via psycopg2", rows)
        return rows
    finally:
        try:
            conn.close()
        except Exception:
            pass


# --- Main task wrapper -----------------------------------------------------------
def task_ingest_and_write(*, fetcher_module: Optional[Any] = None) -> Dict[str, Any]:
    """
    Run ingestion: fetch, normalize, and write to DB.
    Returns a dict with status, rows_written, last_date, and optional errors.
    """
    try:
        mod = fetcher_module or _import_fetcher_module()
        if mod is None:
            msg = "No fetcher module available"
            logger.error(msg)
            return {"status": "fetcher_missing", "error": msg}

        # The fetcher module is expected to expose a function that returns a DataFrame.
        # Try common function names for compatibility.
        fetch_fns = ["fetch_all", "ingest", "run", "fetch_prices", "get_prices"]
        df = None
        for fn in fetch_fns:
            if hasattr(mod, fn):
                try:
                    df = getattr(mod, fn)()
                    logger.info("Fetched data using %s.%s", mod.__name__, fn)
                    break
                except TypeError:
                    # maybe requires args; try without args anyway
                    try:
                        df = getattr(mod, fn)(None)
                        break
                    except Exception:
                        continue

        # If module exposes a DataFrame variable directly
        if df is None and hasattr(mod, "DATAFRAME"):
            df = getattr(mod, "DATAFRAME")

        if df is None:
            msg = "Fetcher module did not return a DataFrame"
            logger.error(msg)
            return {"status": "fetch_failed", "error": msg}

        # Normalize DataFrame: ensure expected columns and types
        # Example normalization: rename Date -> Date, Adj_Close -> Adj_Close, ticker -> ticker
        # Keep original columns if present; user can adapt this mapping to their fetcher.
        expected = {
            "Date": "Date",
            "Adj_Close": "Adj_Close",
            "Close": "Close",
            "High": "High",
            "Low": "Low",
            "Open": "Open",
            "Volume": "Volume",
            "ticker": "ticker",
            "Ticker": "ticker",
        }
        # Build normalized DataFrame with canonical column names
        normalized = {}
        for src, dst in expected.items():
            if src in df.columns:
                normalized[dst] = df[src]
        # If ticker not present, try to infer from module or add a column
        if "ticker" not in normalized:
            ticker = getattr(mod, "TICKER", None) or os.getenv("INGESTION_TICKER")
            if ticker:
                normalized["ticker"] = pd.Series([ticker] * len(df))
        # Create DataFrame
        final = pd.DataFrame(normalized)

        # Ensure Date column is datetime.date or datetime64
        if "Date" in final.columns:
            final["Date"] = pd.to_datetime(final["Date"]).dt.date

        # Lowercase column names to match DB helper mapping
        final.columns = [c if c == "Date" else c for c in final.columns]

        rows = write_prices_to_db(final)
        last_date = None
        if "Date" in final.columns and len(final) > 0:
            last_date = str(final["Date"].max())

        logger.info("Completed ingestion wrapper: %s", {"status": "ok", "rows_written": rows, "last_date": last_date})
        return {"status": "ok", "rows_written": rows, "last_date": last_date}

    except Exception as exc:
        logger.exception("DB write failed -> %s", exc)
        return {"status": "db_write_failed", "error": str(exc)}


# --- Backwards-compatible run() entrypoint ---------------------------------------
def run(*args, **kwargs):
    """
    Thin compatibility shim expected by older orchestrator code.
    """
    return task_ingest_and_write(*args, **kwargs)


# If module executed directly, run the task once (useful for manual testing)
if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO)
    res = task_ingest_and_write()
    print(res)