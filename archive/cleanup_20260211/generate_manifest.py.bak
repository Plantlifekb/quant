# tools/generate_manifest.py
import os, subprocess, json, csv, yaml, hashlib, datetime
ROOT = os.getcwd()
def list_files():
    try:
        out = subprocess.check_output(["git","ls-files"], text=True)
        files = [f for f in out.splitlines() if f.endswith(".py")]
    except Exception:
        files = []
        for dirpath,_,filenames in os.walk(ROOT):
            for fn in filenames:
                if fn.endswith(".py"):
                    files.append(os.path.relpath(os.path.join(dirpath,fn), ROOT))
    return sorted(files)

def short_purpose(path):
    name = os.path.basename(path)
    return f"Script {name} â€” purpose to be filled by owner"

def checksum(path):
    try:
        h = hashlib.sha256()
        with open(path,"rb") as f:
            h.update(f.read())
        return h.hexdigest()
    except Exception:
        return ""

files = list_files()
manifest = {"generated_at": datetime.datetime.now(timezone.utc).isoformat()+"Z", "repo_root": ROOT, "scripts": []}
for p in files:
    entry = {
        "name": os.path.basename(p),
        "path": p.replace("\\","/"),
        "owner": "",
        "purpose": short_purpose(p),
        "inputs": "",
        "outputs": "",
        "side_effects": "",
        "dependencies": "",
        "last_modified": datetime.datetime.fromtimestamp(os.path.getmtime(path), datetime.timezone.utc).isoformat()
        "test_coverage": "unit: no; integration: no",
        "repro_steps": "",
        "acceptance_tests": "",
        "known_limitations": "",
        "checksum": checksum(p)
    }
    manifest["scripts"].append(entry)

os.makedirs("repo_docs", exist_ok=True)
with open("repo_docs/script_manifest.yaml","w") as f:
    yaml.safe_dump(manifest, f, sort_keys=False)
with open("repo_docs/script_manifest.csv","w", newline="") as f:
    writer = csv.writer(f)
    header = list(manifest["scripts"][0].keys())
    writer.writerow(header)
    for s in manifest["scripts"]:
        writer.writerow([s.get(h,"") for h in header])
print("Wrote repo_docs/script_manifest.yaml and .csv")

