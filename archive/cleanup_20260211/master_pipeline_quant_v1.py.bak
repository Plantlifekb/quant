#!/usr/bin/env python3
r"""
C:\Quant\scripts\master_pipeline_quant_v1.py

Master orchestrator for Quant pipeline:
- Build strategy returns from attribution (merge optimiser weights, normalise, clip, stable cumulation)
- Produce weekly picks from optimiser output
- Verify outputs
- Archive old generated files (conservative cleanup)
- Exit non-zero on failure so Task Scheduler surfaces errors
"""

import csv
import json
import logging
import sys
import traceback
from datetime import datetime, timezone, timedelta
from pathlib import Path

import numpy as np
import pandas as pd

# ----------------------------------------------------------------------
# Configuration
# ----------------------------------------------------------------------
ROOT = Path(r"C:\Quant")
SCRIPTS = ROOT / "scripts"
DATA = ROOT / "data"
ANALYTICS = DATA / "analytics"
REFERENCE = DATA / "reference"
LOGS = ROOT / "logs"
ARCHIVE = ROOT / "archive"

# Files
ATTRIBUTION_FILE = ANALYTICS / "attribution_quant_v2.parquet"
STRAT_RET_FILE = ANALYTICS / "strategy_returns.parquet"
STRAT_MANIFEST = ANALYTICS / "strategy_returns_manifest.json"
STRAT_RET_FIXED = ANALYTICS / "strategy_returns_fixed.parquet"

OPTIMISER_FILE = ANALYTICS / "optimiser_regime_quant_v1.parquet"
SECMASTER_FILE = REFERENCE / "securities_master.parquet"
WEEKLY_PICKS_FILE = ANALYTICS / "quant_weekly_picks_quant_v1.parquet"
PRICE_RETURNS_FILE = ANALYTICS / "price_returns.parquet"

DAILY_STATUS = LOGS / "daily_status.csv"

# Parameters
TOP_N = 10
PORTFOLIO_TYPE = "long_only"
CLIP_DAILY = 0.5
ARCHIVE_OLDER_DAYS = 30

# Hardening / tolerances
MISSING_RETURN_FAIL_THRESHOLD = 0.10  # fail if >10% of expected weight+ticker pairs missing returns
MISSING_RETURN_TREAT_AS = 0.0  # conservative fill for missing returns

# Verification thresholds
MAX_LONG_ONLY_CUM = 1000.0
MIN_OPTIMISER_SUM_ABS = 1e-6
FRESHNESS_HOURS = 48

# Logging
LOGS.mkdir(parents=True, exist_ok=True)
ARCHIVE.mkdir(parents=True, exist_ok=True)
logfile = LOGS / f"master_pipeline_{datetime.now(timezone.utc).strftime('%Y%m%d_%H%M%S')}.log"
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s %(message)s",
    handlers=[logging.FileHandler(logfile), logging.StreamHandler(sys.stdout)],
)


# ----------------------------------------------------------------------
# Utilities
# ----------------------------------------------------------------------
def fail(msg: str, exc: Exception = None, code: int = 1):
    logging.error(msg)
    if exc:
        logging.error("Exception: %s", exc)
        traceback.print_exc()
    logging.error("Exiting with code %d", code)
    sys.exit(code)


def write_daily_status(manifest: dict, weekly_rows: int, final_long_cum: float):
    LOGS.mkdir(parents=True, exist_ok=True)
    header = ["run_at_utc", "strategy_rows", "weekly_rows", "final_long_cum", "unit_converted", "clip_value", "method"]
    row = [
        datetime.now(timezone.utc).isoformat(),
        manifest.get("rows", ""),
        weekly_rows,
        final_long_cum,
        manifest.get("unit_converted", ""),
        manifest.get("clip_value", ""),
        manifest.get("method", ""),
    ]
    write_header = not DAILY_STATUS.exists()
    with DAILY_STATUS.open("a", newline="") as f:
        writer = csv.writer(f)
        if write_header:
            writer.writerow(header)
        writer.writerow(row)


# ----------------------------------------------------------------------
# Step 0: Basic freshness checks
# ----------------------------------------------------------------------
def check_data_freshness():
    files = list(DATA.rglob("*"))
    if not files:
        logging.warning("No files under data directory")
        return
    newest = max(files, key=lambda p: p.stat().st_mtime)
    newest_time = datetime.fromtimestamp(newest.stat().st_mtime, timezone.utc)
    age = datetime.now(timezone.utc) - newest_time
    logging.info("Newest data file: %s (age %s)", newest, age)
    if age > timedelta(hours=FRESHNESS_HOURS):
        logging.warning("Data freshness: newest file older than %d hours", FRESHNESS_HOURS)


# ----------------------------------------------------------------------
# Step 1: Build strategy returns
# ----------------------------------------------------------------------
def build_strategy_returns():
    logging.info("Starting build_strategy_returns")
    # Prefer per-instrument attribution path if attribution contains ticker
    if ATTRIBUTION_FILE.exists():
        try:
            df = pd.read_parquet(ATTRIBUTION_FILE)
        except Exception as e:
            fail("Failed to read attribution parquet", e, code=3)

        if "date" not in df.columns:
            fail("Attribution missing 'date' column", code=4)
        df["date"] = pd.to_datetime(df["date"], errors="coerce")

        # If attribution contains per-instrument rows with ticker, use attribution path
        if "ticker" in df.columns and df["ticker"].notna().any():
            logging.info("Using per-instrument attribution path")
            return _build_from_attribution(df)

        # If attribution lacks ticker but contains aggregated portfolio returns, use aggregated fallback
        if "total_return" in df.columns and "ticker" not in df.columns:
            logging.info("Attribution appears aggregated; using aggregated attribution fallback")
            return _build_from_aggregated_attribution(df)

        # Otherwise fall through to optimiser x price returns if available
        logging.info("Attribution present but not usable for per-instrument normalization; falling back to optimiser x price returns if available")

    # Optimiser x price returns path
    return _build_from_optimiser_and_prices()


def _build_from_attribution(df: pd.DataFrame):
    method = "attribution_per_instrument"
    # Attempt to merge optimiser weights if optimiser exists
    if OPTIMISER_FILE.exists():
        try:
            opt_df = pd.read_parquet(OPTIMISER_FILE)
            if "date" in opt_df.columns:
                opt_df["date"] = pd.to_datetime(opt_df["date"], errors="coerce")
            if "ticker" in opt_df.columns:
                opt_small = opt_df[["date", "ticker", "weight"]].copy()
                opt_small["date"] = pd.to_datetime(opt_small["date"], errors="coerce")
                df = df.merge(opt_small, on=["date", "ticker"], how="left", suffixes=("", "_opt"))
                if "weight" not in df.columns or df["weight"].isnull().all():
                    df["weight"] = df.get("weight_opt")
                else:
                    df["weight"] = df["weight"].fillna(df.get("weight_opt"))
                if "weight_opt" in df.columns:
                    df = df.drop(columns=["weight_opt"])
                logging.info("Merged optimiser weights into attribution")
        except Exception as e:
            logging.warning("Failed to merge optimiser weights into attribution: %s", e)

    # Build per-row contribution
    if {"factor_contrib", "alpha_contrib", "idio_contrib"}.issubset(df.columns):
        df["contrib"] = (
            df["factor_contrib"].fillna(0.0)
            + df["alpha_contrib"].fillna(0.0)
            + df["idio_contrib"].fillna(0.0)
        )
    elif "total_return" in df.columns:
        df["contrib"] = df["total_return"].fillna(0.0)
    else:
        fail("Attribution lacks contribution and total_return columns", code=5)

    # If weight/exposure exists, normalise contributions to returns per date
    if "weight" in df.columns:
        try:
            expo = (
                df.groupby("date")["weight"]
                .apply(lambda s: s.abs().sum())
                .rename("total_abs_exposure")
                .reset_index()
            )
            df = df.merge(expo, on="date", how="left")
            df["return_est"] = df.apply(
                lambda r: (r["contrib"] / r["total_abs_exposure"])
                if pd.notna(r["total_abs_exposure"]) and r["total_abs_exposure"] != 0
                else r["contrib"],
                axis=1,
            )
            logging.info("Normalized contributions by total_abs_exposure per date")
        except Exception as e:
            logging.warning("Normalization by weight failed; falling back to contrib as return_est: %s", e)
            df["return_est"] = df["contrib"]
    else:
        df["return_est"] = df["contrib"]

    # Aggregate positive contributions as LONG_ONLY and negative as LONG_SHORT
    long = (
        df[df["return_est"] > 0]
        .groupby("date")["return_est"]
        .sum()
        .reset_index()
        .rename(columns={"return_est": "total_return"})
    )
    long["strategy"] = "LONG_ONLY"

    short = (
        df[df["return_est"] < 0]
        .groupby("date")["return_est"]
        .sum()
        .reset_index()
        .rename(columns={"return_est": "total_return"})
    )
    short["strategy"] = "LONG_SHORT"

    out = pd.concat([long, short], ignore_index=True).sort_values(["strategy", "date"]).reset_index(drop=True)

    return _finalize_and_write(out, method, provenance={"attribution_file": str(ATTRIBUTION_FILE), "optimiser_file": str(OPTIMISER_FILE) if OPTIMISER_FILE.exists() else None})


def _build_from_aggregated_attribution(df: pd.DataFrame):
    method = "aggregated_attribution"
    agg = df.groupby("date")["total_return"].sum().reset_index().rename(columns={"total_return": "total_return"})
    long = agg[agg["total_return"] > 0].copy()
    long["strategy"] = "LONG_ONLY"
    short = agg[agg["total_return"] < 0].copy()
    short["strategy"] = "LONG_SHORT"
    out = pd.concat([long, short], ignore_index=True).sort_values(["strategy", "date"]).reset_index(drop=True)
    return _finalize_and_write(out, method, provenance={"attribution_file": str(ATTRIBUTION_FILE)})


def _build_from_optimiser_and_prices():
    method = "optimiser_x_price_returns"
    opt_file = OPTIMISER_FILE
    pr_file = PRICE_RETURNS_FILE

    if not opt_file.exists():
        fail(f"Optimiser file not found: {opt_file}", code=2)
    if not pr_file.exists():
        fail(f"Price returns file not found: {pr_file}", code=3)

    try:
        opt = pd.read_parquet(opt_file)
    except Exception as e:
        fail("Failed to read optimiser parquet", e, code=4)
    try:
        pr = pd.read_parquet(pr_file)
    except Exception as e:
        fail("Failed to read price returns parquet", e, code=5)

    if "date" not in opt.columns or "ticker" not in opt.columns or "weight" not in opt.columns:
        fail("Optimiser must contain date, ticker, weight", code=6)
    if "date" not in pr.columns or "ticker" not in pr.columns or "return" not in pr.columns:
        fail("Price returns must contain date, ticker, return", code=7)

    opt["date"] = pd.to_datetime(opt["date"], errors="coerce").dt.date
    pr["date"] = pd.to_datetime(pr["date"], errors="coerce").dt.date

    if "portfolio_type" in opt.columns:
        opt = opt[opt["portfolio_type"] == PORTFOLIO_TYPE].copy()
        if opt.empty:
            fail(f"No rows for portfolio_type={PORTFOLIO_TYPE} in optimiser", code=8)

    try:
        opt_small = opt[["date", "ticker", "weight"]].copy()
        pr_small = pr[["date", "ticker", "return"]].copy()

        merged = opt_small.merge(pr_small, on=["date", "ticker"], how="left")
        merged['has_return'] = merged['return'].notna()
        missing_frac = 1.0 - merged['has_return'].mean()
        logging.info("Missing returns fraction: %.2f%%", missing_frac * 100.0)
        if missing_frac > MISSING_RETURN_FAIL_THRESHOLD:
            fail(f"Too many missing price returns: {missing_frac:.2%}", code=9)

        merged['return'] = merged['return'].fillna(MISSING_RETURN_TREAT_AS)
        merged["contrib"] = merged["weight"] * merged["return"]
        daily = merged.groupby("date", as_index=False)["contrib"].sum().rename(columns={"contrib": "total_return"})
    except Exception as e:
        fail("Failed to compute portfolio returns from optimiser and price returns", e, code=10)

    long = daily[daily["total_return"] > 0].copy()
    long["strategy"] = "LONG_ONLY"
    short = daily[daily["total_return"] < 0].copy()
    short["strategy"] = "LONG_SHORT"
    out = pd.concat([long, short], ignore_index=True).sort_values(["strategy", "date"]).reset_index(drop=True)

    provenance = {"optimiser_file": str(opt_file), "price_returns_file": str(pr_file)}
    return _finalize_and_write(out, method, provenance=provenance)


def _finalize_and_write(out: pd.DataFrame, method: str, provenance: dict = None):
    unit_converted = False
    if (out["total_return"].abs() > 1.0).mean() > 0.05:
        logging.info("Detected many returns > 1.0; converting percent->decimal by dividing by 100")
        out["total_return"] = out["total_return"] / 100.0
        unit_converted = True

    out["total_return_clipped"] = out["total_return"].clip(lower=-CLIP_DAILY, upper=CLIP_DAILY)

    parts = []
    for strat in sorted(out["strategy"].unique()):
        sub = out[out["strategy"] == strat].sort_values("date").set_index("date").copy()
        sub["log1p"] = np.log1p(sub["total_return_clipped"].clip(lower=-0.999999))
        sub["cum"] = np.expm1(sub["log1p"].cumsum())
        parts.append(
            sub.reset_index()[["date", "strategy", "total_return_clipped", "cum"]].rename(
                columns={"total_return_clipped": "total_return"}
            )
        )

    final = pd.concat(parts, ignore_index=True).sort_values(["strategy", "date"])

    try:
        final.to_parquet(STRAT_RET_FILE, index=False)
        final.to_parquet(STRAT_RET_FIXED, index=False)
    except Exception as e:
        fail("Failed to write strategy returns parquet", e, code=11)

    manifest = {
        "rows": int(len(final)),
        "unit_converted": bool(unit_converted),
        "clip_value": float(CLIP_DAILY),
        "date_min": str(final["date"].min()) if not final.empty else None,
        "date_max": str(final["date"].max()) if not final.empty else None,
        "long_rows": int((final["strategy"] == "LONG_ONLY").sum()),
        "short_rows": int((final["strategy"] == "LONG_SHORT").sum()),
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "method": method,
        "provenance": provenance or {},
    }
    try:
        STRAT_MANIFEST.write_text(json.dumps(manifest, indent=2))
    except Exception as e:
        logging.warning("Failed to write manifest: %s", e)

    logging.info("WROTE strategy returns (%d rows) and manifest (method=%s)", len(final), method)
    return manifest, final


# ----------------------------------------------------------------------
# Step 2: Build weekly picks
# ----------------------------------------------------------------------
def build_weekly_picks():
    logging.info("Starting build_weekly_picks")
    if not OPTIMISER_FILE.exists():
        fail(f"Optimiser file not found: {OPTIMISER_FILE}", code=20)

    try:
        opt = pd.read_parquet(OPTIMISER_FILE)
    except Exception as e:
        fail("Failed to read optimiser parquet", e, code=21)

    if "date" not in opt.columns:
        fail("Optimiser output missing 'date' column", code=22)

    opt["date"] = pd.to_datetime(opt["date"], errors="coerce").dt.date

    if "portfolio_type" in opt.columns:
        df_lo = opt[opt["portfolio_type"] == PORTFOLIO_TYPE].copy()
        if df_lo.empty:
            fail(f"No rows found for portfolio_type='{PORTFOLIO_TYPE}' in optimiser output", code=23)
        opt = df_lo

    latest_date = opt["date"].max()
    df_latest = opt[opt["date"] == latest_date].copy()
    if df_latest.empty:
        fail("No rows found for latest optimiser date", code=24)

    if "weight" not in df_latest.columns:
        fail("Expected 'weight' column in optimiser output", code=25)

    df_latest = df_latest.sort_values("weight", ascending=False).head(TOP_N)

    if not SECMASTER_FILE.exists():
        fail(f"Securities master not found: {SECMASTER_FILE}", code=26)
    sec = pd.read_parquet(SECMASTER_FILE)

    required_cols = {"ticker", "company_name", "sector"}
    missing = required_cols - set(sec.columns)
    if missing:
        fail(f"Securities master missing required columns: {', '.join(sorted(missing))}", code=27)

    df = df_latest.merge(sec, on="ticker", how="left")
    df = df.sort_values("weight", ascending=False).reset_index(drop=True)
    df["rank"] = df.index + 1

    df_out = df[
        [
            "date",
            "rank",
            "ticker",
            "company_name",
            "sector",
            "weight",
        ]
    ].rename(columns={"date": "as_of_date"})

    OUTPUT_DIR = WEEKLY_PICKS_FILE.parent
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    try:
        df_out.to_parquet(WEEKLY_PICKS_FILE, index=False)
    except Exception as e:
        fail("Failed to write weekly picks parquet", e, code=28)

    logging.info("WROTE weekly picks (%d rows) for %s", len(df_out), latest_date)
    return df_out


# ----------------------------------------------------------------------
# Step 3: Verification functions
# ----------------------------------------------------------------------
def verify_strategy_returns():
    logging.info("Verifying strategy returns")
    if not STRAT_RET_FILE.exists() or not STRAT_MANIFEST.exists():
        fail("Strategy returns or manifest missing", code=30)

    try:
        m = json.loads(STRAT_MANIFEST.read_text())
    except Exception as e:
        logging.warning("Failed to read manifest: %s", e)
        m = None

    try:
        df = pd.read_parquet(STRAT_RET_FILE)
    except Exception as e:
        fail("Failed to read strategy returns parquet", e, code=31)

    problems = []
    if not pd.to_numeric(df["cum"], errors="coerce").notna().all():
        problems.append("Non-finite cum values")

    dates = df["date"].dropna().sort_values().unique()
    if len(dates) == 0:
        problems.append("No dates in strategy returns")

    if set(df["strategy"].unique()) != {"LONG_ONLY", "LONG_SHORT"}:
        problems.append("Missing strategy labels")

    finals = df.groupby("strategy")["cum"].last().to_dict()
    logging.info("Strategy final cum values: %s", finals)

    long_cum = float(finals.get("LONG_ONLY", 0.0))
    if abs(long_cum) > MAX_LONG_ONLY_CUM:
        problems.append(f"LONG_ONLY final cumulative {long_cum:.2f} exceeds threshold {MAX_LONG_ONLY_CUM}")

    if problems:
        logging.error("Strategy verification problems: %s", problems)
        fail("Strategy verification failed: " + "; ".join(problems), code=32)

    logging.info("Strategy verification OK")
    return finals


def verify_weekly_picks():
    logging.info("Verifying weekly picks")
    if not WEEKLY_PICKS_FILE.exists():
        fail("Weekly picks file missing", code=40)

    try:
        df = pd.read_parquet(WEEKLY_PICKS_FILE)
    except Exception as e:
        fail("Failed to read weekly picks parquet", e, code=41)

    required = {"as_of_date", "rank", "ticker", "weight"}
    missing = required - set(df.columns)
    if missing:
        fail(f"weekly picks missing columns: {missing}", code=42)

    if len(df) != TOP_N:
        fail(f"weekly picks row count {len(df)} != TOP_N {TOP_N}", code=43)
    if df["rank"].duplicated().any():
        fail("duplicate ranks found in weekly picks", code=44)
    if df["ticker"].isnull().any():
        fail("null tickers present in weekly picks", code=45)

    logging.info("Weekly picks verification OK rows: %d", len(df))
    return {"rows": len(df)}


# ----------------------------------------------------------------------
# Step 4: Cleanup / archive
# ----------------------------------------------------------------------
def cleanup_archive():
    logging.info("Running cleanup/archive of old generated files")
    cutoff = datetime.now(timezone.utc) - timedelta(days=ARCHIVE_OLDER_DAYS)
    moved = []
    for p in ANALYTICS.glob("strategy_returns_*.parquet"):
        try:
            mtime = datetime.fromtimestamp(p.stat().st_mtime, timezone.utc)
            if mtime < cutoff:
                dest = ARCHIVE / p.name
                p.rename(dest)
                moved.append(str(dest))
        except Exception as e:
            logging.warning("Failed to archive %s: %s", p, e)
    logging.info("Archived %d files", len(moved))
    return moved


# ----------------------------------------------------------------------
# Main orchestration
# ----------------------------------------------------------------------
def main():
    logging.info("=== MASTER PIPELINE START ===")
    check_data_freshness()

    # Optional ingestion
    try:
        import subprocess, os
        PY = sys.executable or "python"
        ingestion_script = SCRIPTS / "ingestion" / "build_prices_quant_v1.py"
        if ingestion_script.exists():
            logging.info("Starting ingestion step")
            r = subprocess.run(f'"{PY}" "{ingestion_script}"', shell=True)
            if r.returncode != 0:
                fail("Ingestion failed", code=1)
        else:
            logging.info("No ingestion script found; skipping ingestion.")
    except Exception as e:
        logging.warning("Ingestion step encountered an error: %s", e)

    try:
        manifest, strat_df = build_strategy_returns()
    except SystemExit as e:
        fail("build_strategy_returns failed", e, code=getattr(e, "code", 1))
    except Exception as e:
        fail("Unexpected error in build_strategy_returns", e)

    try:
        finals = verify_strategy_returns()
    except SystemExit as e:
        fail("verify_strategy_returns failed", e, code=getattr(e, "code", 1))
    except Exception as e:
        fail("Unexpected error in verify_strategy_returns", e)

    try:
        weekly_df = build_weekly_picks()
    except SystemExit as e:
        fail("build_weekly_picks failed", e, code=getattr(e, "code", 1))
    except Exception as e:
        fail("Unexpected error in build_weekly_picks", e)

    try:
        verify_weekly_picks()
    except SystemExit as e:
        fail("verify_weekly_picks failed", e, code=getattr(e, "code", 1))
    except Exception as e:
        fail("Unexpected error in verify_weekly_picks", e)

    try:
        moved = cleanup_archive()
    except Exception as e:
        logging.warning("cleanup_archive encountered an error: %s", e)
        moved = []

    final_long_cum = float(finals.get("LONG_ONLY", 0.0))
    write_daily_status(manifest, weekly_df.shape[0] if 'weekly_df' in locals() else 0, final_long_cum)

    logging.info("=== MASTER PIPELINE COMPLETED SUCCESSFULLY ===")
    logging.info("Manifest: %s", manifest)
    logging.info("Archived files: %s", moved)
    sys.exit(0)


if __name__ == "__main__":
    main()




