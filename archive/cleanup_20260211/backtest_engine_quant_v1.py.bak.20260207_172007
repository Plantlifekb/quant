    df.to_csv(BACKTEST_FILE, index=False)
    logger.info(f"Backtest dataset written: {BACKTEST_FILE}")
    logger.info(f"Rows: {len(df):,}")
    logger.info("=== Backtest engine done ===")

    return df

# --------------------------------------------------------------------------------------------------
# ENTRY POINT
# --------------------------------------------------------------------------------------------------

if __name__ == "__main__":
    logger = get_logger("backtest_engine_quant_v1")
