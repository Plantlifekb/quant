+import pandas as pd
+from quant.common.db import get_engine
+
+_engine = None
+
+def engine():
+    global _engine
+    if _engine is None:
+        _engine = get_engine()
+    return _engine
+
+def query(sql, params=None):
+    return pd.read_sql(sql, engine(), params=params)
+
+def get_health_summary():
+    sql = """
+    SELECT
+      (SELECT MAX(date)::text FROM prices) AS prices_date,
+      (SELECT MAX(updated_at)::text FROM fundamentals) AS fundamentals_date
+    """
+    df = query(sql)
+    return {
+        "prices_date": df.at[0, "prices_date"],
+        "fundamentals_date": df.at[0, "fundamentals_date"],
+    }
+
