+from dash import Input, Output, html, callback_context
+from quant.dashboard import db as dashboard_db
+from quant.dashboard.tabs import overview, prices, returns, signals, strategies
+
+def register_callbacks(app):
+    @app.callback(
+        Output("page-content", "children"),
+        [
+            Input("tab-overview", "n_clicks"),
+            Input("tab-prices", "n_clicks"),
+            Input("tab-returns", "n_clicks"),
+            Input("tab-signals", "n_clicks"),
+            Input("tab-strategies", "n_clicks"),
+        ],
+    )
+    def render_tab(n_overview, n_prices, n_returns, n_signals, n_strategies):
+        ctx = callback_context
+        if not ctx.triggered:
+            return overview.layout()
+        button_id = ctx.triggered[0]["prop_id"].split(".")[0]
+        if button_id == "tab-prices":
+            return prices.layout()
+        if button_id == "tab-returns":
+            return returns.layout()
+        if button_id == "tab-signals":
+            return signals.layout()
+        if button_id == "tab-strategies":
+            return strategies.layout()
+        return overview.layout()
+
+    @app.callback(Output("last-run", "children"), [])
+    def last_run():
+        try:
+            info = dashboard_db.get_health_summary()
+            return html.Div([html.Small(f"Prices: {info['prices_date']}  Fundamentals: {info['fundamentals_date']}")])
+        except Exception:
+            return html.Div([html.Small("Health: unavailable")])
